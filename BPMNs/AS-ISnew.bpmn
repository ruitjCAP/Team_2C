<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ComplianceAlignmentReview" targetNamespace="http://example.com/bpmn/compliance-alignment-review" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.2">
  <bpmn:process id="ComplianceAlignmentReviewProcess" name="Compliance Alignment Review" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Approver" name="Approver / Senior Management">
        <bpmn:flowNodeRef>Task_EscalatedApproval</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Specialists" name="Specialist Stakeholders">
        <bpmn:flowNodeRef>Task_SpecialistReview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Compliance" name="Compliance">
        <bpmn:flowNodeRef>Task_IntakeReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RegisterCase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalyzeChange</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PrepareDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CommunicateDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StoreEvidence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_InfoComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SpecialistNeeded</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_EscalationRequired</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Business" name="Business Owner / Process Owner">
        <bpmn:flowNodeRef>Task_SubmitRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProvideClarification</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_SubmitNeed</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_SubmitNeed" name="Need for review identified">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_SubmitRequest" name="Submit process change request">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_IntakeReview" name="Review intake and scope">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_InfoComplete" name="Information complete?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ProvideClarification" name="Provide clarification / missing documents">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_RegisterCase" name="Register case and classify request">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AnalyzeChange" name="Compare current vs proposed process">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SpecialistNeeded" name="Specialist input needed?">
      <bpmn:incoming>Flow_8</bpmn:incoming>
      <bpmn:outgoing>Flow_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_SpecialistReview" name="Review by Legal / Risk / AML / IT">
      <bpmn:incoming>Flow_9</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_PrepareDecision" name="Prepare decision and rationale">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_EscalationRequired" name="Escalation required?">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_EscalatedApproval" name="Approve / reject escalated case">
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_CommunicateDecision" name="Communicate decision and conditions">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReceiveDecision" name="Receive outcome and next actions">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_StoreEvidence" name="Store evidence and close case">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1s7gpwv">
        <bpmn:targetRef>DataStoreReference_1rinovk</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_CaseClosed" name="Case closed">
      <bpmn:incoming>Flow_19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_SubmitNeed" targetRef="Task_SubmitRequest" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_SubmitRequest" targetRef="Task_IntakeReview" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_IntakeReview" targetRef="Gateway_InfoComplete" />
    <bpmn:sequenceFlow id="Flow_4" name="Yes" sourceRef="Gateway_InfoComplete" targetRef="Task_RegisterCase" />
    <bpmn:sequenceFlow id="Flow_5" name="No" sourceRef="Gateway_InfoComplete" targetRef="Task_ProvideClarification" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_ProvideClarification" targetRef="Task_IntakeReview" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_RegisterCase" targetRef="Task_AnalyzeChange" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_AnalyzeChange" targetRef="Gateway_SpecialistNeeded" />
    <bpmn:sequenceFlow id="Flow_9" name="Yes" sourceRef="Gateway_SpecialistNeeded" targetRef="Task_SpecialistReview" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_SpecialistReview" targetRef="Task_AnalyzeChange" />
    <bpmn:sequenceFlow id="Flow_11" name="No / complete" sourceRef="Gateway_SpecialistNeeded" targetRef="Task_PrepareDecision" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_PrepareDecision" targetRef="Gateway_EscalationRequired" />
    <bpmn:sequenceFlow id="Flow_13" name="Yes" sourceRef="Gateway_EscalationRequired" targetRef="Task_EscalatedApproval" />
    <bpmn:sequenceFlow id="Flow_14" name="No" sourceRef="Gateway_EscalationRequired" targetRef="Task_CommunicateDecision" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_EscalatedApproval" targetRef="Task_CommunicateDecision" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_CommunicateDecision" targetRef="Task_ReceiveDecision" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_CommunicateDecision" targetRef="Task_StoreEvidence" />
    <bpmn:sequenceFlow id="Flow_18" sourceRef="Task_ReceiveDecision" targetRef="Task_StoreEvidence" />
    <bpmn:sequenceFlow id="Flow_19" sourceRef="Task_StoreEvidence" targetRef="EndEvent_CaseClosed" />
    <bpmn:dataStoreReference id="DataStoreReference_1rinovk" name="Database store" />
  </bpmn:process>
